@page
@using System.Globalization
@model MyRazorApp.Pages.Index

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
     <title></title>
</head>
<body>
<div>
   <table>
       <thead>
           <tr>
                    <td>ID</td>
                    <td>Title</td>
                    <td>Price</td>
           </tr>
       </thead>
       <tbody>
           @foreach(var Category in Model.Categories)
           {
               <tr>
                    <td>@Category.Id</td>
                    <td>@Category.Title</td>
                    <td>@Category.Price.ToString("C", new CultureInfo("pt-BR"))</td>
               </tr>
            }
       </tbody>
   </table>
</div>
</body>
</html>
